{
	"$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
	"plugins": ["./modules/biome/arrowbodystyle.grit"],
	"files": {
		"includes": ["**", "!!modules"]
	},
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"formatter": {
		"lineWidth": 100
	},
	"linter": {
		"rules": {
			"complexity": {
				"useLiteralKeys": "off"
			},
			"correctness": {
				"noInvalidPositionAtImportRule": "off"
			},
			"nursery": {
				"useSortedClasses": {
					"level": "warn",
					"options": {
						"functions": ["cn"]
					}
				}
			},
			"style": {
				"noDefaultExport": "warn",
				"noNonNullAssertion": "off"
			},
			"suspicious": {
				"noExplicitAny": "off"
			}
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		},
		"formatter": {
			"quoteStyle": "single"
		}
	},
	"html": {
		"formatter": {
			"indentScriptAndStyle": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single"
		}
	},
	"overrides": [
		{
			"includes": ["**/*.svelte"],
			"linter": {
				"rules": {
					"style": {
						"useConst": "off",
						"useImportType": "off"
					},
					"correctness": {
						"noUnusedVariables": "off",
						"noUnusedImports": "off"
					}
				}
			}
		},
		{
			"includes": ["**/*.config.*"],
			"linter": {
				"rules": {
					"style": {
						"noDefaultExport": "off"
					}
				}
			}
		}
	]
}
