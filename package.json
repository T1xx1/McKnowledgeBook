{
	"name": "mcknowledgebook",
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"dev": "pnpm run modules:build && astro dev",
		"build": "pnpm run modules:build && astro build",
		"format": "biome format --write",
		"predeploy": "pnpm run build",
		"modules:build": "turbo run build"
	},
	"devDependencies": {
		"@astrojs/starlight": "^0.38.3",
		"@astrojs/starlight-tailwind": "^5.0.0",
		"@astrojs/svelte": "^8.0.5",
		"@biomejs/biome": "^2.4.12",
		"@mc/metadata": "workspace:*",
		"@tailwindcss/vite": "^4.2.2",
		"astro": "^6.1.8",
		"sharp": "^0.34.5",
		"starlight-image-zoom": "^0.14.1",
		"starlight-links-validator": "^0.23.0",
		"svelte": "^5.55.4",
		"tailwindcss": "^4.2.2",
		"tsfix": "workspace:*",
		"turbo": "^2.9.6",
		"typescript": "^6.0.3"
	}
}
